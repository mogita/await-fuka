{
	"name": "await-fuka",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"build": "bun scripts/build.ts",
		"typecheck": "tsc --noEmit",
		"format": "biome format --write src scripts",
		"prepare": "simple-git-hooks"
	},
	"simple-git-hooks": {
		"pre-commit": "bun run format && git update-index --again"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@types/bun": "^1.3.13",
		"simple-git-hooks": "^2.13.1",
		"typescript": "^6.0.2"
	}
}
